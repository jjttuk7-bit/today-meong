# OPENAI_API_KEY: Required for OpenAI API calls.
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# ELEVENLABS_API_KEY: Optional. When set, narration uses ElevenLabs multilingual_v2
# (higher quality, more natural Korean). Falls back to OpenAI TTS if not set.
# Get your key at https://elevenlabs.io
ELEVENLABS_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
